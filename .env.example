# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Your Databricks workspace hostname (no https://)
DATABRICKS_HOST=compass-product-data-engineering.cloud.databricks.com

# Optional: pin a specific SQL warehouse ID to skip auto-discovery
# Find it in: Compute → SQL Warehouses → your warehouse → Connection details → HTTP path
# e.g. /sql/1.0/warehouses/abc123def456  →  DATABRICKS_WAREHOUSE_ID=abc123def456
DATABRICKS_WAREHOUSE_ID=
